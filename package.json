{
  "name": "subscription-based-billing-system",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack Subscription-Based Billing System — React frontend + Node.js/Express backend + MongoDB",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "seed": "cd backend && npm run seed",
    "build:frontend": "cd frontend && npm run build",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:seed": "docker-compose exec backend node src/seeds/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
