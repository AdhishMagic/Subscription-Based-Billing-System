# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/subbill

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_key_2026
JWT_REFRESH_SECRET=change_me_refresh_secret_key_2026
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
